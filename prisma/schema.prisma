// ─── AI Team Studio — Prisma Schema ───
// PostgreSQL database for the AI-Powered Product Delivery OS

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users & Auth ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String?
  role          UserRole  @default(USER)
  status        UserStatus @default(ACTIVE)
  plan          UserPlan   @default(STARTER)
  avatarColor   String    @default("#f59e0b")
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  ownedProjects   Project[]       @relation("ProjectOwner")
  projectMembers  ProjectMember[]
  cards           Card[]          @relation("CardAssignee")
  decisions       Decision[]      @relation("DecisionOwner")
  auditLogs       AuditLog[]
  notifications   Notification[]
  sessions        Session[]
  accounts        Account[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum UserPlan {
  STARTER
  PRO
  ENTERPRISE
}

// ─── Projects ───────────────────────────────────────────────────────────────

model Project {
  id           String        @id @default(cuid())
  name         String
  description  String        @default("")
  status       ProjectStatus @default(ACTIVE)
  currentStage String        @default("Business Analysis")
  completion   Int           @default(0) // 0-100
  color        String        @default("#f59e0b")
  ownerId      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  owner         User             @relation("ProjectOwner", fields: [ownerId], references: [id])
  members       ProjectMember[]
  cards         Card[]
  decisions     Decision[]
  agents        Agent[]
  sdlcStages    SDLCStage[]
  llmUsage      LLMUsage[]
  documents     Document[]
  auditLogs     AuditLog[]
  notifications Notification[]
  chatMessages      ChatMessage[]
  gitBranches       GitBranch[]
  gitPullRequests   GitPullRequest[]
  gitReleases       GitRelease[]
  wireframes        Wireframe[]
  events            Event[]
  artifacts         Artifact[]
  orchestrationRuns OrchestrationRun[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("member") // owner, admin, member, viewer
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

// ─── Cards (Kanban) ─────────────────────────────────────────────────────────

model Card {
  id              String       @id @default(cuid())
  title           String
  description     String       @default("")
  type            CardType     @default(TASK)
  state           CardState    @default(PLANNED)
  priority        Priority     @default(MEDIUM)
  projectId       String
  assigneeId      String?
  ownerAgentId    String?
  parentId        String?
  linkedDecisionId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User?     @relation("CardAssignee", fields: [assigneeId], references: [id])
  ownerAgent Agent?    @relation(fields: [ownerAgentId], references: [id])
  parent     Card?     @relation("CardHierarchy", fields: [parentId], references: [id])
  children   Card[]    @relation("CardHierarchy")

  @@index([projectId])
  @@index([state])
  @@map("cards")
}

enum CardType {
  EPIC
  FEATURE
  TASK
  QA
  DECISION_BLOCKER
}

enum CardState {
  PLANNED
  IN_PROGRESS
  UNDER_REVIEW
  TESTING
  BLOCKED
  DONE
  RELEASED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── Decisions ──────────────────────────────────────────────────────────────

model Decision {
  id              String         @id @default(cuid())
  trigger         String
  context         String         @default("")
  riskRating      RiskRating     @default(MEDIUM)
  recommendation  String         @default("")
  approvedOption  String?
  status          DecisionStatus @default(DRAFTED)
  ownerId         String
  projectId       String
  createdAt       DateTime       @default(now())
  approvedAt      DateTime?
  updatedAt       DateTime       @updatedAt

  // Relations
  owner   User              @relation("DecisionOwner", fields: [ownerId], references: [id])
  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  options DecisionOption[]

  @@index([projectId])
  @@map("decisions")
}

model DecisionOption {
  id          String     @id @default(cuid())
  name        String
  description String     @default("")
  pros        String[]   // PostgreSQL array
  cons        String[]
  risk        RiskRating @default(MEDIUM)
  effort      Effort     @default(MEDIUM)
  decisionId  String

  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@map("decision_options")
}

enum DecisionStatus {
  DRAFTED
  OPTIONS_COLLECTED
  RECOMMENDED
  AWAITING_APPROVAL
  APPROVED
  REJECTED
  IMPLEMENTED
  VERIFIED
}

enum RiskRating {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Effort {
  LOW
  MEDIUM
  HIGH
}

// ─── Agents ─────────────────────────────────────────────────────────────────

model Agent {
  id          String      @id @default(cuid())
  name        String
  shortName   String
  group       AgentGroup
  status      AgentStatus @default(IDLE)
  currentTask String?
  avatar      String      @default("🤖")
  projectId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cards        Card[]
  chatMessages ChatMessage[]

  @@index([projectId])
  @@map("agents")
}

enum AgentGroup {
  GOVERNANCE
  SDLC
  ENGINEERING
  PLATFORM
  AI_COST
}

enum AgentStatus {
  IDLE
  WORKING
  WAITING
  BLOCKED
}

// ─── SDLC Pipeline ──────────────────────────────────────────────────────────

model SDLCStage {
  id         String     @id @default(cuid())
  name       String
  order      Int
  status     StageStatus @default(PENDING)
  gatePassed Boolean     @default(false)
  projectId  String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
  @@map("sdlc_stages")
}

enum StageStatus {
  COMPLETED
  ACTIVE
  PENDING
  BLOCKED
}

// ─── Documents ──────────────────────────────────────────────────────────────

model Document {
  id         String       @id @default(cuid())
  title      String
  type       DocumentType
  status     DocStatus    @default(DRAFT)
  content    String       @default("")
  wordCount  Int          @default(0)
  sections   Int          @default(0)
  locked     Boolean      @default(false)
  owner      String
  ownerAvatar String     @default("📋")
  projectId  String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("documents")
}

enum DocumentType {
  BRD
  SDD
  API_SPEC
  RUNBOOK
  ADR
}

enum DocStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
}

// ─── Notifications ──────────────────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  description String           @default("")
  read        Boolean          @default(false)
  actionLabel String?
  actionHref  String?
  userId      String
  projectId   String?
  createdAt   DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

enum NotificationType {
  DECISION
  COMPLETION
  PR
  FAILURE
  AGENT
  DEPLOY
  SECURITY
  BUILD
}

// ─── Audit Logs ─────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  target    String
  details   String   @default("")
  ipAddress String   @default("")
  userId    String
  projectId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── LLM Usage Tracking ────────────────────────────────────────────────────

model LLMUsage {
  id         String   @id @default(cuid())
  tokensUsed Int
  cost       Float
  provider   String   // openai, anthropic, ollama
  model      String   @default("")
  agentName  String   @default("")
  projectId  String
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
  @@map("llm_usage")
}

// ─── Billing / Transactions ─────────────────────────────────────────────────

model Transaction {
  id        String            @id @default(cuid())
  userName  String
  userEmail String
  amount    Float
  plan      UserPlan
  status    TransactionStatus @default(COMPLETED)
  createdAt DateTime          @default(now())

  @@map("transactions")
}

enum TransactionStatus {
  COMPLETED
  PENDING
  FAILED
  REFUNDED
}

// ─── Chat Messages ─────────────────────────────────────────────────────────

model ChatMessage {
  id                  String      @id @default(cuid())
  role                MessageRole
  content             String
  thinking            String?
  agentId             String?
  projectId           String
  orchestrationRunId  String?     // Links to the OrchestrationRun that produced this message
  artifacts           String?     // JSON array of {name, type}
  createdAt           DateTime    @default(now())

  agent   Agent?  @relation(fields: [agentId], references: [id])
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
  @@map("chat_messages")
}

enum MessageRole {
  USER
  AGENT
  SYSTEM
}

// ─── Git & Releases ──────────────────────────────────────────────────────────

model GitBranch {
  id         String       @id @default(cuid())
  name       String
  status     BranchStatus @default(ACTIVE)
  lastCommit String       @default("")
  author     String       @default("")
  behind     Int          @default(0)
  ahead      Int          @default(0)
  projectId  String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
  @@map("git_branches")
}

model GitPullRequest {
  id        String      @id @default(cuid())
  number    Int
  title     String
  branch    String
  status    PRStatus    @default(OPEN)
  author    String      @default("")
  avatar    String      @default("")
  reviewers String[]
  checks    CheckStatus @default(PENDING)
  additions Int         @default(0)
  deletions Int         @default(0)
  comments  Int         @default(0)
  projectId String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId])
  @@map("git_pull_requests")
}

model GitRelease {
  id        String        @id @default(cuid())
  version   String
  date      String        @default("")
  status    ReleaseStatus @default(DRAFT)
  changes   Int           @default(0)
  features  String[]
  projectId String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
  @@index([projectId])
  @@map("git_releases")
}

enum BranchStatus {
  ACTIVE
  MERGED
  STALE
}

enum PRStatus {
  OPEN
  MERGED
  CLOSED
}

enum CheckStatus {
  PASSING
  FAILING
  PENDING
}

enum ReleaseStatus {
  RELEASED
  DRAFT
  PRE_RELEASE
}

// ─── Wireframes ──────────────────────────────────────────────────────────────

model Wireframe {
  id          String          @id @default(cuid())
  title       String
  screen      String          @default("")
  status      WireframeStatus @default(DRAFT)
  device      DeviceType      @default(DESKTOP)
  owner       String          @default("")
  ownerAvatar String          @default("")
  components  Int             @default(0)
  version     Int             @default(1)
  projectId   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("wireframes")
}

enum WireframeStatus {
  DRAFT
  REVIEW
  APPROVED
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
}

// ─── LLM Provider Configuration (BYOM) ────────────────────────────────────

model LLMProviderConfig {
  id              String      @id @default(cuid())
  provider        String      // 'openai' | 'anthropic' | 'ollama' | 'custom'
  displayName     String      @default("")
  apiKeyEncrypted String?     // AES-256-GCM encrypted
  baseUrl         String?     // For Ollama, custom endpoints
  organizationId  String?     // For OpenAI
  defaultModel    String
  isActive        Boolean     @default(true)
  scope           ConfigScope // USER, PROJECT, AGENT

  // Polymorphic ownership
  userId         String?
  projectId      String?
  agentShortName String?      // When scope = AGENT, which agent this config applies to

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([projectId, agentShortName])
  @@map("llm_provider_configs")
}

enum ConfigScope {
  USER
  PROJECT
  AGENT
}

// ─── Orchestration Events ──────────────────────────────────────────────────

model Event {
  id        String   @id @default(cuid())
  type      String   // 'MessageProcessed', 'TaskCreated', 'DecisionRequested', etc.
  actor     String   // Agent shortName
  payload   String   @default("{}") // JSON stringified
  projectId String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, type])
  @@index([createdAt])
  @@map("events")
}

// ─── Agent Artifacts ───────────────────────────────────────────────────────

model Artifact {
  id         String       @id @default(cuid())
  name       String       // e.g., 'gateway-refactor.md'
  type       ArtifactType
  content    String       @default("")
  ownerAgent String       // Agent shortName that produced it
  version    Int          @default(1)
  messageId  String?      // ChatMessage that generated this artifact
  projectId  String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, ownerAgent])
  @@map("artifacts")
}

enum ArtifactType {
  CODE
  DOCUMENT
  CONFIG
  WIREFRAME
  TEST
}

// ─── Orchestration Runs ────────────────────────────────────────────────────

model OrchestrationRun {
  id           String    @id @default(cuid())
  status       RunStatus @default(RUNNING)
  userMessage  String
  routedTo     String    // Agent shortName
  autoRouted   Boolean   @default(false)
  delegations  String[]  // Chain of agent shortNames
  tokensTotal  Int       @default(0)
  costTotal    Float     @default(0)
  latencyMs    Int       @default(0)
  errorMessage String?
  projectId    String
  userId       String
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
  @@map("orchestration_runs")
}

enum RunStatus {
  RUNNING
  COMPLETED
  FAILED
  TIMEOUT
}
