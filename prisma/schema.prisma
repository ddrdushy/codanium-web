// ─── AI Team Studio — Prisma Schema ───
// PostgreSQL database for the AI-Powered Product Delivery OS

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users & Auth ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String?
  role          UserRole  @default(USER)
  status        UserStatus @default(ACTIVE)
  plan          UserPlan   @default(STARTER)
  avatarColor   String    @default("#f59e0b")
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified DateTime?          // null = not verified, DateTime = when verified

  // Onboarding
  onboardingCompleted   Boolean   @default(false)
  onboardingStep        Int       @default(0)       // 0=not started, 4=done
  onboardingCompletedAt DateTime?

  // Stripe billing
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  subscriptionStatus   SubscriptionStatus @default(NONE)
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?

  // Relations
  ownedProjects   Project[]       @relation("ProjectOwner")
  projectMembers  ProjectMember[]
  cards           Card[]          @relation("CardAssignee")
  decisions       Decision[]      @relation("DecisionOwner")
  auditLogs       AuditLog[]
  notifications   Notification[]
  presence        UserPresence[]
  sessions        Session[]
  accounts        Account[]
  emailTokens     EmailToken[]
  sentInvitations ProjectInvitation[] @relation("SentInvitations")
  apiKeys         ApiKey[]
  ownedOrgs       Organization[]  @relation("OrgOwner")
  orgMemberships  OrgMember[]
  transactions    Transaction[]
  preferences     UserPreferences?
  creditWallet    CreditWallet?
  llmUsages       LLMUsage[]
  feedback        Feedback[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum UserPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  NONE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

// ─── User Preferences ────────────────────────────────────────────────────────

model UserPreferences {
  id                  String   @id @default(cuid())
  userId              String   @unique
  approvalLevel       String   @default("big-stuff")    // everything, big-stuff, autonomous
  communicationStyle  String   @default("simple")       // simple, detailed
  monthlyBudget       Int      @default(500)             // dollars
  alertThreshold      Int      @default(75)              // percentage: 50, 75, 90
  notifyApprovals     Boolean  @default(true)
  notifyProgress      Boolean  @default(true)
  notifyAttention     Boolean  @default(true)
  notifyDailySummary  Boolean  @default(false)
  notifyBudgetAlerts  Boolean  @default(true)
  tutorialCompleted   Boolean  @default(false)
  tutorialStep        Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─── Feedback ──────────────────────────────────────────────────────────────

model Feedback {
  id          String   @id @default(cuid())
  userId      String
  category    String   // BUG, FEATURE, IMPROVEMENT, GENERAL
  rating      Int?     // 1-5
  title       String
  description String
  pageUrl     String?
  projectId   String?
  status      String   @default("NEW") // NEW, IN_REVIEW, RESOLVED, CLOSED
  adminReply  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feedback")
}

// ─── Projects ───────────────────────────────────────────────────────────────

model Project {
  id           String        @id @default(cuid())
  name         String
  description  String        @default("")
  status       ProjectStatus @default(ACTIVE)
  currentStage   String        @default("Idea & Planning")
  pipelinePhase  String        @default("PM_GREETING") // FSM state: PM_GREETING, BA_WORKING, BA_NEEDS_APPROVAL, SA_WORKING, SA_NEEDS_APPROVAL, DO_WORKING, DO_NEEDS_APPROVAL, DEV_WORKING, COMPLETE
  completion     Int           @default(0) // 0-100
  color        String        @default("#f59e0b")

  // Preview tier
  previewTier  String        @default("sandpack") // sandpack, webcontainer, cloud

  // Git integration
  gitProvider       String?   // "github" (future: "gitlab", "bitbucket")
  gitRepoOwner      String?   // e.g. "acme-corp"
  gitRepoName       String?   // e.g. "my-app"
  gitDefaultBranch  String?   @default("main")
  gitTokenEncrypted String?   // AES-256-GCM encrypted PAT
  gitWebhookSecret  String?   // HMAC secret for inbound webhook verification
  gitSyncEnabled    Boolean   @default(false)
  gitLastSyncAt     DateTime?

  orgId        String?
  ownerId      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relations
  owner         User             @relation("ProjectOwner", fields: [ownerId], references: [id])
  organization  Organization?    @relation(fields: [orgId], references: [id])
  members       ProjectMember[]
  cards         Card[]
  decisions     Decision[]
  agents        Agent[]
  sdlcStages    SDLCStage[]
  llmUsage      LLMUsage[]
  documents     Document[]
  auditLogs     AuditLog[]
  notifications Notification[]
  chatMessages      ChatMessage[]
  gitBranches       GitBranch[]
  gitCommits        GitCommit[]
  gitPullRequests   GitPullRequest[]
  gitReleases       GitRelease[]
  wireframes        Wireframe[]
  events            Event[]
  artifacts         Artifact[]
  orchestrationRuns     OrchestrationRun[]
  deploymentPipelines  DeploymentPipeline[]
  userPresence         UserPresence[]
  invitations          ProjectInvitation[]
  webhookEndpoints     WebhookEndpoint[]
  memories             ProjectMemory[]
  codeExecutions       CodeExecution[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("member") // owner, admin, member, viewer
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

// ─── Cards (Kanban) ─────────────────────────────────────────────────────────

model Card {
  id              String       @id @default(cuid())
  title           String
  description     String       @default("")
  type            CardType     @default(TASK)
  state           CardState    @default(PLANNED)
  priority        Priority     @default(MEDIUM)
  projectId       String
  assigneeId      String?
  ownerAgentId    String?
  parentId        String?
  linkedDecisionId String?
  gitBranchId     String?      // Feature branch for this card's work
  module          String?      // Codebase module scope, e.g. "auth", "payments", "dashboard"
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User?      @relation("CardAssignee", fields: [assigneeId], references: [id])
  ownerAgent Agent?     @relation(fields: [ownerAgentId], references: [id])
  parent     Card?      @relation("CardHierarchy", fields: [parentId], references: [id])
  children   Card[]     @relation("CardHierarchy")
  gitBranch  GitBranch? @relation(fields: [gitBranchId], references: [id])
  artifacts  Artifact[]
  chatMessages ChatMessage[]
  comments   CardComment[]
  llmUsage   LLMUsage[]

  @@index([projectId])
  @@index([state])
  @@index([projectId, module])
  @@map("cards")
}

enum CardType {
  EPIC
  FEATURE
  TASK
  QA
  DECISION_BLOCKER
}

enum CardState {
  PLANNED
  IN_PROGRESS
  UNDER_REVIEW
  TESTING
  BLOCKED
  DONE
  RELEASED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── Card Comments & Sign-offs ──────────────────────────────────────────────

model CardComment {
  id         String           @id @default(cuid())
  cardId     String
  agentName  String           // Agent shortName (e.g. "QA", "SEC", "PM")
  content    String
  type       CardCommentType  @default(COMMENT)
  createdAt  DateTime         @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([cardId, type])
  @@map("card_comments")
}

enum CardCommentType {
  COMMENT
  SIGN_OFF
  REJECTION
  REWORK_REQUEST
}

// ─── Decisions ──────────────────────────────────────────────────────────────

model Decision {
  id              String         @id @default(cuid())
  trigger         String
  context         String         @default("")
  riskRating      RiskRating     @default(MEDIUM)
  recommendation  String         @default("")
  approvedOption  String?
  status          DecisionStatus @default(DRAFTED)
  ownerId         String
  projectId       String
  createdAt       DateTime       @default(now())
  approvedAt      DateTime?
  updatedAt       DateTime       @updatedAt

  // Relations
  owner   User              @relation("DecisionOwner", fields: [ownerId], references: [id])
  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  options DecisionOption[]

  @@index([projectId])
  @@map("decisions")
}

model DecisionOption {
  id          String     @id @default(cuid())
  name        String
  description String     @default("")
  pros        String[]   // PostgreSQL array
  cons        String[]
  risk        RiskRating @default(MEDIUM)
  effort      Effort     @default(MEDIUM)
  decisionId  String

  decision Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@map("decision_options")
}

enum DecisionStatus {
  DRAFTED
  OPTIONS_COLLECTED
  RECOMMENDED
  AWAITING_APPROVAL
  APPROVED
  REJECTED
  IMPLEMENTED
  VERIFIED
}

enum RiskRating {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Effort {
  LOW
  MEDIUM
  HIGH
}

// ─── Agents ─────────────────────────────────────────────────────────────────

model Agent {
  id          String      @id @default(cuid())
  name        String
  shortName   String
  group       AgentGroup
  status      AgentStatus @default(IDLE)
  currentTask String?
  avatar      String      @default("🤖")
  projectId   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cards        Card[]
  chatMessages ChatMessage[]

  @@index([projectId])
  @@map("agents")
}

enum AgentGroup {
  GOVERNANCE
  SDLC
  ENGINEERING
  PLATFORM
  AI_COST
}

enum AgentStatus {
  IDLE
  WORKING
  WAITING
  BLOCKED
}

// ─── SDLC Pipeline ──────────────────────────────────────────────────────────

model SDLCStage {
  id         String     @id @default(cuid())
  name       String
  order      Int
  status     StageStatus @default(PENDING)
  gatePassed Boolean     @default(false)
  projectId  String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
  @@map("sdlc_stages")
}

enum StageStatus {
  COMPLETED
  ACTIVE
  PENDING
  BLOCKED
}

// ─── Documents ──────────────────────────────────────────────────────────────

model Document {
  id         String       @id @default(cuid())
  title      String
  type       DocumentType
  status     DocStatus    @default(DRAFT)
  content    String       @default("")
  wordCount  Int          @default(0)
  sections   Int          @default(0)
  locked     Boolean      @default(false)
  owner      String
  ownerAvatar String     @default("📋")
  projectId  String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("documents")
}

enum DocumentType {
  BRD
  SDD
  API_SPEC
  RUNBOOK
  ADR
  CONSTITUTION
  DESIGN_SYSTEM
  WIREFRAME
}

enum DocStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
}

// ─── Notifications ──────────────────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  description String           @default("")
  read        Boolean          @default(false)
  actionLabel String?
  actionHref  String?
  userId      String
  projectId   String?
  createdAt   DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

enum NotificationType {
  DECISION
  COMPLETION
  PR
  FAILURE
  AGENT
  DEPLOY
  SECURITY
  BUILD
}

// ─── Audit Logs ─────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  target    String
  details   String   @default("")
  ipAddress String   @default("")
  userId    String
  projectId String?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── LLM Usage Tracking ────────────────────────────────────────────────────

model LLMUsage {
  id               String      @id @default(cuid())
  tokensUsed       Int
  promptTokens     Int         @default(0) // input tokens sent to LLM
  completionTokens Int         @default(0) // output tokens generated by LLM
  contextTokens    Int         @default(0) // context window tokens (system prompt + history)
  actualCost       Float       @default(0) // raw provider cost
  markedUpCost     Float?      // actualCost × (1 + markup%) — null for BYOK
  billingType      BillingType @default(PLATFORM)
  provider         String      // openai, anthropic, ollama, mistral, etc.
  model            String      @default("")
  agentName        String      @default("")
  projectId        String
  userId           String?     // who triggered the call
  createdAt        DateTime    @default(now())

  cardId           String?     // Card this usage is attributed to (for per-card cost tracking)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])
  card    Card?   @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
  @@index([cardId])
  @@index([createdAt])
  @@map("llm_usage")
}

enum BillingType {
  PLATFORM  // deducted from credit wallet
  BYOK      // user's own key — no credit deduction
}

// ─── Billing / Transactions ─────────────────────────────────────────────────

model Transaction {
  id                    String            @id @default(cuid())
  userName              String
  userEmail             String
  amount                Float
  plan                  UserPlan
  status                TransactionStatus @default(COMPLETED)
  userId                String?
  stripePaymentIntentId String?           @unique
  stripeInvoiceId       String?
  createdAt             DateTime          @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("transactions")
}

enum TransactionStatus {
  COMPLETED
  PENDING
  FAILED
  REFUNDED
}

// ─── Chat Messages ─────────────────────────────────────────────────────────

model ChatMessage {
  id                  String      @id @default(cuid())
  role                MessageRole
  content             String
  thinking            String?
  agentId             String?
  projectId           String
  orchestrationRunId  String?     // Links to the OrchestrationRun that produced this message
  artifacts           String?     // JSON array of {name, type}
  cardId              String?     // Scoped to a specific card/module for context filtering
  createdAt           DateTime    @default(now())

  agent   Agent?  @relation(fields: [agentId], references: [id])
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  card    Card?   @relation(fields: [cardId], references: [id])

  @@index([projectId])
  @@index([createdAt])
  @@index([projectId, cardId])
  @@map("chat_messages")
}

enum MessageRole {
  USER
  AGENT
  SYSTEM
}

// ─── Git & Releases ──────────────────────────────────────────────────────────

model GitBranch {
  id         String       @id @default(cuid())
  name       String
  status     BranchStatus @default(ACTIVE)
  lastCommit String       @default("")
  author     String       @default("")
  behind     Int          @default(0)
  ahead      Int          @default(0)
  projectId  String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cards   Card[]
  commits GitCommit[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("git_branches")
}

model GitCommit {
  id        String   @id @default(cuid())
  message   String
  author    String              // Agent shortName or user email
  sha       String              // 7-char generated hash
  branchId  String
  projectId String
  createdAt DateTime @default(now())

  branch  GitBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([projectId])
  @@map("git_commits")
}

model GitPullRequest {
  id        String      @id @default(cuid())
  number    Int
  title     String
  branch    String
  status    PRStatus    @default(OPEN)
  author    String      @default("")
  avatar    String      @default("")
  reviewers String[]
  checks    CheckStatus @default(PENDING)
  additions Int         @default(0)
  deletions Int         @default(0)
  comments  Int         @default(0)
  projectId String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId])
  @@map("git_pull_requests")
}

model GitRelease {
  id        String        @id @default(cuid())
  version   String
  date      String        @default("")
  status    ReleaseStatus @default(DRAFT)
  changes   Int           @default(0)
  features  String[]
  projectId String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
  @@index([projectId])
  @@map("git_releases")
}

enum BranchStatus {
  ACTIVE
  MERGED
  STALE
}

enum PRStatus {
  OPEN
  MERGED
  CLOSED
}

enum CheckStatus {
  PASSING
  FAILING
  PENDING
}

enum ReleaseStatus {
  RELEASED
  DRAFT
  PRE_RELEASE
}

// ─── Wireframes ──────────────────────────────────────────────────────────────

model Wireframe {
  id          String          @id @default(cuid())
  title       String
  screen      String          @default("")
  status      WireframeStatus @default(DRAFT)
  device      DeviceType      @default(DESKTOP)
  owner       String          @default("")
  ownerAvatar String          @default("")
  components  Int             @default(0)
  version     Int             @default(1)
  content     String?         // Markdown wireframe content
  penData     Json?           // Pencil .pen format JSON data
  projectId   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("wireframes")
}

enum WireframeStatus {
  DRAFT
  REVIEW
  APPROVED
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
}

// ─── LLM Provider Configuration (BYOM) ────────────────────────────────────

model LLMProviderConfig {
  id              String      @id @default(cuid())
  provider        String      // 'openai' | 'anthropic' | 'ollama' | 'custom'
  displayName     String      @default("")
  apiKeyEncrypted String?     // AES-256-GCM encrypted
  baseUrl         String?     // For Ollama, custom endpoints
  organizationId  String?     // For OpenAI
  defaultModel    String
  isActive        Boolean     @default(true)
  scope           ConfigScope // USER, PROJECT, AGENT, PLATFORM
  priority        Int         @default(0) // lower number = higher priority, 0 = primary

  // Polymorphic ownership
  userId         String?
  projectId      String?
  agentShortName String?      // When scope = AGENT, which agent this config applies to

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([projectId, agentShortName])
  @@map("llm_provider_configs")
}

enum ConfigScope {
  USER
  PROJECT
  AGENT
  PLATFORM
}

// ─── Orchestration Events ──────────────────────────────────────────────────

model Event {
  id        String   @id @default(cuid())
  type      String   // 'MessageProcessed', 'TaskCreated', 'DecisionRequested', etc.
  actor     String   // Agent shortName
  payload   String   @default("{}") // JSON stringified
  projectId String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, type])
  @@index([createdAt])
  @@map("events")
}

// ─── Agent Artifacts ───────────────────────────────────────────────────────

model Artifact {
  id         String       @id @default(cuid())
  name       String       // e.g., 'gateway-refactor.md'
  type       ArtifactType
  content    String       @default("")
  ownerAgent String       // Agent shortName that produced it
  version    Int          @default(1)
  messageId  String?      // ChatMessage that generated this artifact
  cardId     String?      // Card this artifact belongs to (branch context)
  module     String?      // Codebase module scope, inherited from card
  projectId  String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  card           Card?           @relation(fields: [cardId], references: [id])
  codeExecutions CodeExecution[]

  @@index([projectId])
  @@index([projectId, ownerAgent])
  @@index([cardId])
  @@index([projectId, module])
  @@map("artifacts")
}

enum ArtifactType {
  CODE
  DOCUMENT
  CONFIG
  WIREFRAME
  TEST
}

// ─── Orchestration Runs ────────────────────────────────────────────────────

model OrchestrationRun {
  id           String    @id @default(cuid())
  status       RunStatus @default(PENDING)
  userMessage  String
  routedTo     String    // Agent shortName
  autoRouted   Boolean   @default(false)
  delegations  String[]  // Chain of agent shortNames
  tokensTotal  Int       @default(0)
  costTotal    Float     @default(0)
  latencyMs    Int       @default(0)
  errorMessage String?
  projectId    String
  userId       String
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  // Queue fields
  priority     Int       @default(0)       // Higher = process first
  retryCount   Int       @default(0)
  maxRetries   Int       @default(3)
  scheduledAt  DateTime  @default(now())   // For delayed execution
  startedAt    DateTime?                   // When processing began
  isBackground Boolean   @default(false)   // false = SSE interactive, true = background
  parentRunId  String?                     // For sub-tasks from delegation
  cardId       String?                     // Scoped to a specific card/module

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
  @@index([status, scheduledAt])
  @@index([projectId, status])
  @@map("orchestration_runs")
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  TIMEOUT
  CANCELLED
}

// ─── Deployment Pipelines ──────────────────────────────────────────────────

model DeploymentPipeline {
  id          String            @id @default(cuid())
  name        String
  environment DeployEnvironment @default(STAGING)
  trigger     PipelineTrigger   @default(MANUAL)
  config      String            @default("{}") // JSON: build cmd, deploy cmd, etc.
  projectId   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    DeploymentRun[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("deployment_pipelines")
}

model DeploymentRun {
  id           String          @id @default(cuid())
  pipelineId   String
  status       DeployRunStatus @default(PENDING)
  currentStage DeployStage     @default(BUILD)
  triggeredBy  String          // "user", agent shortName, or "auto"
  commitHash   String          @default("")
  branch       String          @default("")
  buildLogs    String          @default("")
  testLogs     String          @default("")
  deployLogs   String          @default("")
  errorMessage String?
  durationMs   Int             @default(0)
  projectId    String
  createdAt    DateTime        @default(now())
  startedAt    DateTime?
  completedAt  DateTime?

  pipeline DeploymentPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId])
  @@index([projectId])
  @@index([createdAt])
  @@map("deployment_runs")
}

enum DeployEnvironment {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

enum PipelineTrigger {
  MANUAL
  AGENT
  AUTO_ON_MERGE
  SCHEDULED
}

enum DeployRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum DeployStage {
  BUILD
  TEST
  DEPLOY
  COMPLETE
}

// ─── User Presence (Real-time Collaboration) ─────────────────────────────────

model UserPresence {
  id         String   @id @default(cuid())
  userId     String
  projectId  String
  lastSeenAt DateTime @default(now())
  status     String   @default("online") // online, idle, away

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId, lastSeenAt])
  @@map("user_presence")
}

// ─── Email Tokens (Verification + Password Reset) ──────────────────────────

model EmailToken {
  id        String         @id @default(cuid())
  type      EmailTokenType
  token     String         @unique   // SHA-256 hash of raw token
  email     String                    // Target email address
  expiresAt DateTime
  usedAt    DateTime?                 // null = unused
  userId    String?                   // null for pre-registration
  createdAt DateTime       @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email, type])
  @@map("email_tokens")
}

enum EmailTokenType {
  VERIFICATION
  PASSWORD_RESET
}

// ─── Email Events (Mailjet Webhook Tracking) ────────────────────────────────

model EmailEvent {
  id           String         @id @default(cuid())
  event        EmailEventType
  messageId    String         // Mailjet MessageID
  messageGuid  String?        // Mailjet Message_GUID
  email        String         // Recipient email address
  customId     String?        // CustomID echoed from send call (for correlation)
  timestamp    DateTime       // Mailjet event timestamp

  // Full raw Mailjet event payload as JSON
  payload      String         @default("{}")

  // Denormalized fields for common queries
  smtpReply    String?        // sent events
  url          String?        // click events
  ip           String?        // open/click/unsub events
  bounceError  String?        // bounce/blocked error details
  isHardBounce Boolean?       // bounce: hard_bounce flag
  spamSource   String?        // spam: source

  createdAt    DateTime       @default(now())

  @@index([email])
  @@index([messageId])
  @@index([event])
  @@index([event, timestamp])
  @@map("email_events")
}

enum EmailEventType {
  SENT
  OPEN
  CLICK
  BOUNCE
  SPAM
  BLOCKED
  UNSUB
}

// ─── Project Invitations ────────────────────────────────────────────────────

model ProjectInvitation {
  id          String           @id @default(cuid())
  email       String
  role        String           @default("member") // member, admin, viewer
  status      InvitationStatus @default(PENDING)
  token       String           @unique   // SHA-256 hash
  invitedById String
  projectId   String
  expiresAt   DateTime                    // 7 days from creation
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())

  invitedBy User    @relation("SentInvitations", fields: [invitedById], references: [id])
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email])
  @@index([email])
  @@index([token])
  @@map("project_invitations")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// ─── Webhook Endpoints (Outbound) ────────────────────────────────────────────

model WebhookEndpoint {
  id          String   @id @default(cuid())
  url         String                    // Target URL (https://...)
  secret      String                    // Shared secret for HMAC signing
  events      String[] @default([])     // Event types: ["*"] or ["pr.created", "build.complete"]
  enabled     Boolean  @default(true)
  description String   @default("")
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([projectId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id           String   @id @default(cuid())
  endpointId   String
  eventType    String                    // e.g. "pr.created"
  payload      String   @db.Text         // JSON stringified event payload
  statusCode   Int?                      // HTTP response status (null = pending)
  responseBody String?  @db.Text         // First 1KB of response
  duration     Int?                      // ms
  success      Boolean  @default(false)
  attempt      Int      @default(1)
  error        String?                   // Error message if failed
  deliveredAt  DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([deliveredAt])
  @@map("webhook_deliveries")
}

// ─── API Keys ──────────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique   // SHA-256 hash of raw key
  keyPrefix  String              // "ats_sk_..." (first 12 chars for display)
  scopes     String[]  @default(["read"])
  userId     String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
  @@map("api_keys")
}

// ─── Organizations ──────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  avatarColor String   @default("#3b82f6")
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User          @relation("OrgOwner", fields: [ownerId], references: [id])
  members  OrgMember[]
  projects Project[]

  @@map("organizations")
}

model OrgMember {
  id       String   @id @default(cuid())
  orgId    String
  userId   String
  role     OrgRole  @default(MEMBER)
  joinedAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// ─── Project Memory (Agent Knowledge Store) ─────────────────────────────────

model ProjectMemory {
  id          String   @id @default(cuid())
  projectId   String
  category    String   // "idea", "audience", "priority", "feature", "decision", "preference"
  content     String   // The actual fact/memory
  source      String   @default("user") // "user", "agent:BA", "agent:SA", "system"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, category])
  @@map("project_memories")
}

// ─── Credit Wallet & Transactions ───────────────────────────────────────────

model CreditWallet {
  id                 String    @id @default(cuid())
  userId             String    @unique
  balance            Float     @default(0)    // current spendable balance in USD
  lifetimeAdded      Float     @default(0)    // total ever added (purchased + free)
  lifetimeUsed       Float     @default(0)    // total ever spent
  freeCreditsGranted Float     @default(0)    // amount given at signup
  freeCreditsExpiry  DateTime?               // when free credits expire
  freeDataConsent    Boolean   @default(false) // consented to data use for improvement
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]

  @@map("credit_wallets")
}

model CreditTransaction {
  id                    String                @id @default(cuid())
  walletId              String
  amount                Float                 // positive = credit in, negative = debit out
  type                  CreditTransactionType
  description           String                @default("")
  stripePaymentIntentId String?               @unique
  stripeSessionId       String?               @unique
  llmUsageId            String?               // which LLM call caused the debit
  createdAt             DateTime              @default(now())

  wallet CreditWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([createdAt])
  @@map("credit_transactions")
}

enum CreditTransactionType {
  FREE_GRANT   // onboarding free credits
  PURCHASE     // Stripe top-up
  USAGE        // LLM call debit (negative)
  REFUND       // Stripe refund (positive)
  ADJUSTMENT   // admin manual correction
  EXPIRY       // free credits expired (negative)
}

// ─── Admin Settings (Key-Value) ─────────────────────────────────────────────

model AdminSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String   @default("")

  @@map("admin_settings")
}

// ─── Code Execution (Sandboxed Runs) ────────────────────────────────────────

model CodeExecution {
  id           String          @id @default(cuid())
  status       ExecutionStatus @default(QUEUED)
  language     String                           // typescript, javascript, python, etc.
  code         String          @db.Text         // Source code to execute
  stdin        String          @default("")     // Optional stdin input
  stdout       String          @default("") @db.Text  // Captured stdout
  stderr       String          @default("") @db.Text  // Captured stderr
  exitCode     Int?                              // Process exit code (null = not completed)
  durationMs   Int             @default(0)       // Wall-clock execution time
  memoryUsedMb Float           @default(0)       // Peak memory usage
  errorMessage String?                           // System-level error (not stderr)
  artifactId   String?                           // Source artifact (if from agent code)
  cardId       String?                           // Scoped to card context
  triggeredBy  String          @default("user")  // "user", agent shortName, or "system"
  projectId    String
  createdAt    DateTime        @default(now())
  startedAt    DateTime?
  completedAt  DateTime?

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifact Artifact? @relation(fields: [artifactId], references: [id])

  @@index([projectId])
  @@index([projectId, status])
  @@index([createdAt])
  @@map("code_executions")
}

enum ExecutionStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  TIMEOUT
  CANCELLED
}
