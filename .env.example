# =============================================================================
# AI Team Studio — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string (Docker runs on port 14000 by default)
DATABASE_URL="postgresql://ats_user:ats_secret_2025@localhost:14000/ai_team_studio?schema=public"

# Connection pool tuning (optional — defaults shown)
# DATABASE_POOL_MAX=20             # Max simultaneous connections per process
# DATABASE_IDLE_TIMEOUT=30000      # Close idle connections after 30s (ms)
# DATABASE_POOL_TIMEOUT=10000      # Fail if no connection available within 10s (ms)

# ─── Redis ──────────────────────────────────────────────────────────────────
# Required for: BullMQ queues (email, orchestration), VS Code heartbeat, config cache
REDIS_URL="redis://localhost:14003"

# ─── NextAuth / Auth ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_TRUST_HOST=true

# App URL — used for email links, OAuth callbacks, and Stripe redirects
NEXTAUTH_URL="https://yourdomain.com"
APP_URL="https://yourdomain.com"

# ─── OAuth Providers (optional) ─────────────────────────────────────────────
# Google — https://console.cloud.google.com/apis/credentials
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# GitHub — https://github.com/settings/developers
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""

# ─── Email — Mailjet ────────────────────────────────────────────────────────
# Required for: email verification, password reset, subscription emails
# Get keys at: https://app.mailjet.com/account/apikeys
# If not set, emails are logged to console only (dev mode)
# MAILJET_API_KEY="your-mailjet-api-key"
# MAILJET_SECRET_KEY="your-mailjet-secret-key"

# ─── Stripe Billing ─────────────────────────────────────────────────────────
# Required for: subscription checkout, customer portal, webhook handling
# Get keys at: https://dashboard.stripe.com/apikeys
# Webhook secret: https://dashboard.stripe.com/webhooks
# Webhook endpoint to register: POST /api/webhooks/stripe
# Events to enable: checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.payment_succeeded, invoice.payment_failed
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs — create products in Stripe Dashboard > Products
# STRIPE_PRICE_STARTER="price_..."    # $19/mo
# STRIPE_PRICE_PRO="price_..."        # $49/mo
# STRIPE_PRICE_ENTERPRISE="price_..." # $299/mo

# ─── LLM Providers ──────────────────────────────────────────────────────────
# Configured via Admin Settings UI at /admin/settings (stored encrypted in DB).
# These env vars are fallbacks only if admin settings are not yet configured.
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
# OLLAMA_BASE_URL="http://localhost:11434"
